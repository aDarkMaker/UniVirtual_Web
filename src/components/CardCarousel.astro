---
import type { CollectionEntry } from 'astro:content';
import '@/styles/card-carousel.css';

interface CardItem {
  id: number;
  title: string;
  type: keyof typeof cardTypes;
}

interface Props {
  people: CollectionEntry<'people'>[];
}

interface CardType {
  background?: string;
  avatar?: string;
  avatarMotion: AvatarMotion;
  usePlaceholder: boolean;
}

interface AvatarMotion {
  avatarWidth: number;
  avatarHeight: number;
  avatarHiddenRight: number;
  avatarShownRight: number;
  avatarStartX: number;
  avatarStartY: number;
  avatarStartScale: number;
  avatarStartRotate: number;
  avatarEndX: number;
  avatarEndY: number;
  avatarEndScale: number;
  avatarEndRotate: number;
}

const xiaokeAvatarMotion = {
  avatarWidth: 212,
  avatarHeight: 108,
  avatarHiddenRight: 16,
  avatarShownRight: -96,
  avatarStartX: -34,
  avatarStartY: -36,
  avatarStartScale: 0.68,
  avatarStartRotate: -8,
  avatarEndX: 0,
  avatarEndY: -60,
  avatarEndScale: 1.5,
  avatarEndRotate: 0,
} satisfies AvatarMotion;

const lanfengAvatarMotion = {
  avatarWidth: 212,
  avatarHeight: 108,
  avatarHiddenRight: 16,
  avatarShownRight: -96,
  avatarStartX: -34,
  avatarStartY: -36,
  avatarStartScale: 0.68,
  avatarStartRotate: -8,
  avatarEndX: 0,
  avatarEndY: -60,
  avatarEndScale: 1.5,
  avatarEndRotate: 0,
} satisfies AvatarMotion;

const cardTypes = {
  xiaoke: {
    background: '/img/Card/background/background_xiaoke.png',
    avatar: '/img/Card/Avatar/Avatar_xiaoke.png',
    avatarMotion: xiaokeAvatarMotion,
    usePlaceholder: false,
  },
  lanfeng: {
    background: '/img/Card/background/background_lanfeng.png',
    avatar: '/img/Card/Avatar/Avatar_lanfeng.png',
    avatarMotion: lanfengAvatarMotion,
    usePlaceholder: false,
  },
  placeholder: {
    avatarMotion: xiaokeAvatarMotion,
    usePlaceholder: true,
  },
} satisfies Record<string, CardType>;

const { people } = Astro.props as Props;
const cards: CardItem[] = people.map((person, index) => ({
  id: index + 1,
  title: person.data.name,
  type: person.data.cardType,
}));
---

<div class="carousel-container">
  <div class="carousel-stage">
    <div class="carousel-arc" id="carousel-arc">
      {cards.map((card, index) => (
        (() => {
          const cardType = cardTypes[card.type];
          const avatarMotion = cardType.avatarMotion;
          return (
            <button class="carousel-card" data-index={index} data-id={card.id} type="button" aria-label={`选择${card.title}`}>
              <div class="card-content">
                {cardType.usePlaceholder ? (
                  <>
                    <div class="card-illustration card-illustration--placeholder"></div>
                    <div
                      class="card-character card-character--placeholder"
                      style={`--avatar-width:${avatarMotion.avatarWidth}px;--avatar-height:${avatarMotion.avatarHeight}%;--avatar-hidden-right:${avatarMotion.avatarHiddenRight}px;--avatar-shown-right:${avatarMotion.avatarShownRight}px;--avatar-start-x:${avatarMotion.avatarStartX}%;--avatar-start-y:${avatarMotion.avatarStartY}%;--avatar-start-scale:${avatarMotion.avatarStartScale};--avatar-start-rotate:${avatarMotion.avatarStartRotate}deg;--avatar-end-x:${avatarMotion.avatarEndX}%;--avatar-end-y:${avatarMotion.avatarEndY}%;--avatar-end-scale:${avatarMotion.avatarEndScale};--avatar-end-rotate:${avatarMotion.avatarEndRotate}deg;`}
                    ></div>
                  </>
                ) : (
                  <>
                    <img class="card-illustration" src={cardType.background} alt={card.title} loading="eager" />
                    <img
                      class="card-character"
                      src={cardType.avatar}
                      alt=""
                      loading="eager"
                      style={`--avatar-width:${avatarMotion.avatarWidth}px;--avatar-height:${avatarMotion.avatarHeight}%;--avatar-hidden-right:${avatarMotion.avatarHiddenRight}px;--avatar-shown-right:${avatarMotion.avatarShownRight}px;--avatar-start-x:${avatarMotion.avatarStartX}%;--avatar-start-y:${avatarMotion.avatarStartY}%;--avatar-start-scale:${avatarMotion.avatarStartScale};--avatar-start-rotate:${avatarMotion.avatarStartRotate}deg;--avatar-end-x:${avatarMotion.avatarEndX}%;--avatar-end-y:${avatarMotion.avatarEndY}%;--avatar-end-scale:${avatarMotion.avatarEndScale};--avatar-end-rotate:${avatarMotion.avatarEndRotate}deg;`}
                    />
                  </>
                )}
              </div>
            </button>
          );
        })()
      ))}
    </div>
  </div>
</div>

<script>
  const arc = document.getElementById('carousel-arc');
  if (!arc) {
    throw new Error('carousel-arc not found');
  }

  const cards = Array.from(arc.querySelectorAll('.carousel-card')) as HTMLButtonElement[];
  const cardCount = cards.length;

  let currentIndex = 0;
  let isAnimating = false;
  let autoTimer: number | undefined;
  let characterTimer: number | undefined;
  let cardStep = 152;
  let mobileCardStep = 248;
  let touchStartX = 0;
  let touchDeltaX = 0;

  const ARC_RADIUS = 220;
  const ARC_DEPTH = 82;
  const VISIBLE_CARDS = 5;
  const WHEEL_COOLDOWN = 360;
  const AUTO_INTERVAL = 10000;
  const CHARACTER_DELAY = 420;
  const mobileQuery = window.matchMedia('(max-width: 768px)');

  function circularDistance(index: number, center: number) {
    let distance = index - center;
    if (distance > cardCount / 2) distance -= cardCount;
    if (distance < -cardCount / 2) distance += cardCount;
    return distance;
  }

  function updateCarousel() {
    const isMobile = mobileQuery.matches;
    cards.forEach((card, index) => {
      const offset = circularDistance(index, currentIndex);
      const distance = Math.abs(offset);
      const limited = Math.min(distance, (VISIBLE_CARDS - 1) / 2 + 1);
      const y = isMobile ? 0 : offset * cardStep;
      const curve = (1 - Math.cos(Math.min(limited, 2.8) / 2.8 * Math.PI * 0.9)) * ARC_RADIUS * 0.24;
      const x = isMobile ? offset * mobileCardStep : -Math.min(ARC_DEPTH, curve);
      const scale = isMobile ? Math.max(0.84, 1 - distance * 0.12) : Math.max(0.78, 1 - distance * 0.08);
      const zIndex = 100 - Math.floor(distance * 10);
      const isVisible = distance <= (VISIBLE_CARDS - 1) / 2 + 0.5;
      const opacity = isVisible ? Math.max(0.36, 1 - distance * 0.16) : 0;
      const isCenter = index === currentIndex;

      card.style.transform = `translate(${x}px, ${y}px) scale(${scale})`;
      card.style.zIndex = String(zIndex);
      card.style.opacity = String(opacity);
      card.style.pointerEvents = isVisible ? 'auto' : 'none';
      card.classList.toggle('is-center', isCenter);
      card.setAttribute('aria-pressed', String(isCenter));
    });
    window.dispatchEvent(new CustomEvent('dossier-change', { detail: { index: currentIndex } }));
  }

  function hideCharacter() {
    cards.forEach((card) => card.classList.remove('is-character-active'));
  }

  function scheduleCharacterReveal() {
    if (mobileQuery.matches) {
      hideCharacter();
      return;
    }
    if (characterTimer) window.clearTimeout(characterTimer);
    hideCharacter();
    characterTimer = window.setTimeout(() => {
      const card = cards[currentIndex];
      if (!card || isAnimating) return;
      card.classList.add('is-character-active');
    }, CHARACTER_DELAY);
  }

  function moveBy(delta: number) {
    currentIndex = (currentIndex + delta + cardCount) % cardCount;
    updateCarousel();
    scheduleCharacterReveal();
  }

  function handleWheel(e: WheelEvent) {
    if (!window.matchMedia('(pointer: fine)').matches) return;
    e.preventDefault();
    if (isAnimating) return;
    isAnimating = true;
    moveBy(e.deltaY > 0 ? 1 : -1);
    restartAutoScroll();
    setTimeout(() => {
      isAnimating = false;
    }, WHEEL_COOLDOWN);
  }

  function handleCardSelect(index: number) {
    if (isAnimating) return;
    if (index === currentIndex) return;
    currentIndex = index;
    updateCarousel();
    scheduleCharacterReveal();
  }

  function updateCardStep() {
    if (mobileQuery.matches) {
      const byViewport = Math.floor(window.innerWidth * 0.72);
      mobileCardStep = Math.max(190, Math.min(280, byViewport));
    } else {
      const availableHeight = window.innerHeight - 300;
      const byViewport = Math.floor(availableHeight / (VISIBLE_CARDS - 1));
      cardStep = Math.max(110, Math.min(160, byViewport));
    }
    updateCarousel();
    scheduleCharacterReveal();
  }

  function restartAutoScroll() {
    if (autoTimer) window.clearInterval(autoTimer);
    autoTimer = window.setInterval(() => {
      if (!isAnimating) {
        moveBy(1);
      }
    }, AUTO_INTERVAL);
  }

  function handleClick(e: Event) {
    const card = (e.target as HTMLElement).closest('.carousel-card') as HTMLButtonElement | null;
    if (!card) return;
    const index = Number(card.dataset.index ?? 0);
    handleCardSelect(index);
    restartAutoScroll();
  }

  function handleTouchStart(e: TouchEvent) {
    touchStartX = e.touches[0]?.clientX ?? 0;
    touchDeltaX = 0;
  }

  function handleTouchMove(e: TouchEvent) {
    const currentX = e.touches[0]?.clientX ?? touchStartX;
    touchDeltaX = currentX - touchStartX;
  }

  function handleTouchEnd() {
    if (!mobileQuery.matches || isAnimating) return;
    if (Math.abs(touchDeltaX) < 36) return;
    isAnimating = true;
    moveBy(touchDeltaX < 0 ? 1 : -1);
    restartAutoScroll();
    setTimeout(() => {
      isAnimating = false;
    }, WHEEL_COOLDOWN);
  }

  function handleKeydown(e: KeyboardEvent) {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      moveBy(1);
      restartAutoScroll();
      return;
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      moveBy(-1);
      restartAutoScroll();
      return;
    }
    if (e.key === 'Enter' || e.key === ' ') {
      const target = (e.target as HTMLElement).closest('.carousel-card') as HTMLButtonElement | null;
      if (!target) return;
      e.preventDefault();
      const index = Number(target.dataset.index ?? 0);
      handleCardSelect(index);
      restartAutoScroll();
    }
  }

  window.addEventListener('wheel', handleWheel, { passive: false });
  window.addEventListener('resize', updateCardStep);
  arc.addEventListener('click', handleClick);
  arc.addEventListener('keydown', handleKeydown);
  arc.addEventListener('touchstart', handleTouchStart, { passive: true });
  arc.addEventListener('touchmove', handleTouchMove, { passive: true });
  arc.addEventListener('touchend', handleTouchEnd, { passive: true });
  updateCardStep();
  restartAutoScroll();
</script>
