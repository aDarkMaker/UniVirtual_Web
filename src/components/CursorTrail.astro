---
import '@/styles/cursor-trail.css';
---

<canvas class="cursor-trail" id="cursor-trail"></canvas>

<script>
	const canvas = document.getElementById('cursor-trail') as HTMLCanvasElement;
	const ctx = canvas.getContext('2d')!;

	type Bubble = {
		x: number;
		y: number;
		vx: number;
		vy: number;
		radius: number;
		targetRadius: number;
		life: number;
		maxLife: number;
		hue: number;
		hueSpeed: number;
		phase: number;
		wobbleSpeed: number;
	};

	const bubbles: Bubble[] = [];
	const MAX = 16;
	const SPAWN_EVERY = 12;
	const LIFE_MIN = 28;
	const LIFE_RANGE = 20;
	const R_MIN = 10;
	const R_RANGE = 18;
	const DARK_HUES = [260, 290, 200, 320, 230];
	const LIGHT_HUES = [210, 250, 330, 170, 280];

	let mx = -200;
	let my = -200;
	let frame = 0;
	let hovering = false;

	function dark() {
		return !document.documentElement.classList.contains('light');
	}

	function resize() {
		const dpr = devicePixelRatio || 1;
		canvas.width = innerWidth * dpr;
		canvas.height = innerHeight * dpr;
		ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
	}

	function spawn(isDark: boolean) {
		if (bubbles.length >= MAX) return;
		const pool = isDark ? DARK_HUES : LIGHT_HUES;
		const hue = pool[Math.floor(Math.random() * pool.length)] + (Math.random() - 0.5) * 20;
		bubbles.push({
			x: mx,
			y: my,
			vx: (Math.random() - 0.5) * 0.7,
			vy: -(Math.random() * 0.4 + 0.25),
			radius: 0,
			targetRadius: R_MIN + Math.random() * R_RANGE,
			life: LIFE_MIN + Math.random() * LIFE_RANGE,
			maxLife: 0,
			hue,
			hueSpeed: (Math.random() - 0.5) * 1.2,
			phase: Math.random() * Math.PI * 2,
			wobbleSpeed: 0.02 + Math.random() * 0.025,
		});
		bubbles[bubbles.length - 1].maxLife = bubbles[bubbles.length - 1].life;
	}

	function draw(b: Bubble, isDark: boolean) {
		const r = b.radius;
		if (r < 1) return;

		const t = b.life / b.maxLife;
		const fade = t < 0.15 ? t / 0.15 : 1;
		const a = fade * (isDark ? 0.6 : 0.45);
		const h = b.hue + b.hueSpeed * (b.maxLife - b.life);
		const s = isDark ? 72 : 52;
		const l = isDark ? 72 : 80;

		ctx.save();
		ctx.translate(b.x, b.y);

		const glow = ctx.createRadialGradient(0, 0, r * 0.4, 0, 0, r * 1.6);
		glow.addColorStop(0, `hsla(${h},${s}%,${l}%,${a * 0.1})`);
		glow.addColorStop(1, `hsla(${h},${s}%,${l}%,0)`);
		ctx.beginPath();
		ctx.arc(0, 0, r * 1.6, 0, Math.PI * 2);
		ctx.fillStyle = glow;
		ctx.fill();

		const mem = ctx.createRadialGradient(0, 0, r * 0.72, 0, 0, r);
		mem.addColorStop(0, `hsla(${h},${s}%,${l}%,0)`);
		mem.addColorStop(0.45, `hsla(${h + 25},${s + 10}%,${l}%,${a * 0.3})`);
		mem.addColorStop(0.82, `hsla(${h + 50},${s}%,${l - 4}%,${a * 0.48})`);
		mem.addColorStop(1, `hsla(${h + 50},${s}%,${l}%,${a * 0.08})`);
		ctx.beginPath();
		ctx.arc(0, 0, r, 0, Math.PI * 2);
		ctx.fillStyle = mem;
		ctx.fill();

		const inner = ctx.createRadialGradient(0, 0, 0, 0, 0, r * 0.75);
		inner.addColorStop(0, `hsla(${h},${s}%,${l + 10}%,${a * 0.07})`);
		inner.addColorStop(1, `hsla(${h + 30},${s}%,${l}%,${a * 0.02})`);
		ctx.beginPath();
		ctx.arc(0, 0, r * 0.75, 0, Math.PI * 2);
		ctx.fillStyle = inner;
		ctx.fill();

		const hlR = r * 0.36;
		ctx.save();
		ctx.translate(-r * 0.26, -r * 0.3);
		ctx.scale(1, 0.6);
		const hl = ctx.createRadialGradient(0, 0, 0, 0, 0, hlR);
		hl.addColorStop(0, `rgba(255,255,255,${a * 0.9})`);
		hl.addColorStop(0.45, `rgba(255,255,255,${a * 0.18})`);
		hl.addColorStop(1, 'rgba(255,255,255,0)');
		ctx.beginPath();
		ctx.arc(0, 0, hlR, 0, Math.PI * 2);
		ctx.fillStyle = hl;
		ctx.fill();
		ctx.restore();

		const hl2R = r * 0.16;
		ctx.save();
		ctx.translate(r * 0.2, r * 0.24);
		ctx.scale(0.55, 1);
		const hl2 = ctx.createRadialGradient(0, 0, 0, 0, 0, hl2R);
		hl2.addColorStop(0, `rgba(255,255,255,${a * 0.4})`);
		hl2.addColorStop(1, 'rgba(255,255,255,0)');
		ctx.beginPath();
		ctx.arc(0, 0, hl2R, 0, Math.PI * 2);
		ctx.fillStyle = hl2;
		ctx.fill();
		ctx.restore();

		ctx.restore();
	}

	function tick() {
		ctx.clearRect(0, 0, canvas.width, canvas.height);
		const isDark = dark();

		for (let i = bubbles.length - 1; i >= 0; i--) {
			const b = bubbles[i];
			b.life--;
			if (b.life <= 0) {
				bubbles.splice(i, 1);
				continue;
			}
			b.radius = b.targetRadius * Math.min(1, (b.maxLife - b.life) / 10);
			b.phase += b.wobbleSpeed;
			b.x += b.vx + Math.sin(b.phase) * 0.25;
			b.y += b.vy;
			b.vy -= 0.002;
			draw(b, isDark);
		}

		if (hovering && ++frame % SPAWN_EVERY === 0) spawn(isDark);
		requestAnimationFrame(tick);
	}

	function onMove(e: MouseEvent) {
		mx = e.clientX;
		my = e.clientY;
		hovering = true;
		canvas.style.display = '';
	}

	function onLeave() {
		hovering = false;
	}

	if (window.matchMedia('(pointer: fine)').matches) {
		canvas.style.display = 'none';
		resize();
		window.addEventListener('resize', resize);
		document.addEventListener('mousemove', onMove);
		document.addEventListener('mouseleave', onLeave);
		requestAnimationFrame(tick);
	} else {
		canvas.style.display = 'none';
	}
</script>

