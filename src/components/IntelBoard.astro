---
import type { CollectionEntry } from 'astro:content';
import '@/styles/intel-board.css';

interface Props {
	people: CollectionEntry<'people'>[];
}

const { people } = Astro.props as Props;
---

<aside class="profile" id="profile">
	{people.map((person, i) => (
		<article class={`profile__card${i === 0 ? ' is-active' : ''}`} data-profile-index={i}>
			<div class="profile__photos">
				{person.data.photos.map((src, pi) => (
					<figure class="profile__photo" style={`--photo-delay:${pi * 0.12}s;`}>
						<img src={`/img/Photo/${src}`} alt="" loading="lazy" />
					</figure>
				))}
			</div>

			<div class="profile__content">
				<div class="profile__hero" style={`--char-count:${person.data.name.length};`}>
					{person.data.name.split('').map((char) => (
						<span class="profile__hero-char">{char}</span>
					))}
				</div>

				<div class="profile__meta">
					<span class="profile__meta-sub">{person.data.subtitle}</span>
					<span class="profile__meta-divider" aria-hidden="true"></span>
					<span class="profile__meta-sub">{person.data.subsubtitle}</span>
				</div>

				<div class="profile__tags">
					{person.data.tags.map((tag, ti) => (
						<span class="profile__tag" style={`--tag-delay:${ti * 0.06}s;`}>{tag}</span>
					))}
				</div>

				<ul class="profile__notes">
					{person.data.notes.map((note, ni) => (
						<li class="profile__note" style={`--note-delay:${ni * 0.08}s;`}>{note}</li>
					))}
				</ul>
			</div>
		</article>
	))}
</aside>

<script>
	const container = document.getElementById('profile');
	if (!container) throw new Error('profile not found');

	const cards = Array.from(container.querySelectorAll('.profile__card')) as HTMLElement[];
	const navInner = document.querySelector('.nav-inner') as HTMLElement | null;
	const carouselStage = document.querySelector('.carousel-stage') as HTMLElement | null;

	const MAX_FONT_SIZE = 128;
	const MIN_FONT_SIZE = 48;

	let activeIndex = 0;

	function setHeroFontSize(card: HTMLElement) {
		const hero = card.querySelector('.profile__hero') as HTMLElement | null;
		if (!hero) return;
		const charCount = Number(hero.style.getPropertyValue('--char-count')) || 3;
		const availableHeight = window.innerHeight - 96;
		const reserved = 360;
		const raw = (availableHeight - reserved) / (charCount * 0.82);
		const fontSize = Math.min(Math.max(raw, MIN_FONT_SIZE), MAX_FONT_SIZE);
		hero.style.setProperty('--hero-font-size', `${fontSize}px`);
	}

	function layoutPhotos(card: HTMLElement) {
		if (!container || !navInner || !carouselStage) return;

		const photosContainer = card.querySelector('.profile__photos') as HTMLElement | null;
		const contentEl = card.querySelector('.profile__content') as HTMLElement | null;
		if (!photosContainer || !contentEl) return;

		const photos = Array.from(photosContainer.querySelectorAll('.profile__photo')) as HTMLElement[];
		if (photos.length === 0) return;

		const containerRect = container.getBoundingClientRect();
		const navRect = navInner.getBoundingClientRect();
		const stageRect = carouselStage.getBoundingClientRect();
		const contentRect = contentEl.getBoundingClientRect();

		const zL = stageRect.right - containerRect.left + 24;
		const zR = contentRect.left - containerRect.left - 24;
		const zT = navRect.bottom - containerRect.top + 8;
		const zB = window.innerHeight - containerRect.top - 8;
		const zW = zR - zL;
		const zH = zB - zT;

		if (zW <= 60 || zH <= 60) return;

		const count = photos.length;
		const cols = Math.ceil(Math.sqrt(count * (zW / zH)));
		const rows = Math.ceil(count / cols);
		const cW = zW / cols;
		const cH = zH / rows;

		photos.forEach((photo, idx) => {
			const img = photo.querySelector('img');
			const ar = img && img.complete && img.naturalWidth > 0
				? img.naturalWidth / img.naturalHeight
				: 4 / 3;

			const col = idx % cols;
			const row = Math.floor(idx / cols);
			const angle = (idx % 3 - 1) * 5;
			const rad = Math.abs(angle) * Math.PI / 180;
			const cs = Math.cos(rad);
			const sn = Math.sin(rad);

			const maxByW = (cW - 20) / (cs + sn / ar);
			const maxByH = (cH - 20) / (sn + cs / ar);
			const pw = Math.min(maxByW, maxByH);

			const px = zL + cW * (col + 0.5);
			const py = zT + cH * (row + 0.5);

			photo.style.width = `${pw}px`;
			photo.style.top = `${py}px`;
			photo.style.left = `${px}px`;
			photo.style.setProperty('--photo-rotate', `${angle}deg`);
			photo.style.setProperty('--photo-z', String(idx + 1));
			photo.style.setProperty('--photo-delay', `${0.75 + idx * 0.14}s`);
			photo.style.setProperty('--float-duration', `${6 + idx * 0.7}s`);
			photo.classList.remove('is-floating');
			photo.addEventListener('animationend', () => {
				photo.classList.add('is-floating');
			}, { once: true });
		});
	}

	function activate(index: number) {
		if (index === activeIndex) return;

		const direction = index > activeIndex ? 'down' : 'up';
		const oldCard = cards[activeIndex];
		const newCard = cards[index];

		oldCard.style.setProperty('--exit-dir', direction === 'down' ? '1' : '-1');
		oldCard.classList.add('is-exiting');
		oldCard.classList.remove('is-active');

		newCard.style.setProperty('--exit-dir', direction === 'down' ? '1' : '-1');
		newCard.classList.remove('is-exiting');
		newCard.querySelectorAll('.profile__photo').forEach((p) => p.classList.remove('is-floating'));
		newCard.style.display = 'flex';

		requestAnimationFrame(() => {
			layoutPhotos(newCard);
			setHeroFontSize(newCard);
			newCard.style.display = '';
			newCard.classList.add('is-active');
		});

		activeIndex = index;
	}

	window.addEventListener('dossier-change', (event) => {
		const ev = event as CustomEvent<{ index: number }>;
		activate(ev.detail?.index ?? 0);
	});

	let resizeTimer: number;
	window.addEventListener('resize', () => {
		clearTimeout(resizeTimer);
		resizeTimer = window.setTimeout(() => {
			relayout();
		}, 120);
	});

	new ResizeObserver(() => {
		clearTimeout(resizeTimer);
		resizeTimer = window.setTimeout(() => {
			relayout();
		}, 120);
	}).observe(container);

	function relayout() {
		setHeroFontSize(cards[activeIndex]);
		layoutPhotos(cards[activeIndex]);
	}

	setHeroFontSize(cards[0]);
	layoutPhotos(cards[0]);
</script>
