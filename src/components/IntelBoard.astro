---
import type { CollectionEntry } from 'astro:content';
import '@/styles/intel-board.css';

type IntelNode = { id: string; label: string; x: number; y: number; size: 'sm' | 'md' };
type IntelEdge = { fromX: number; fromY: number; toX: number; toY: number };
type IntelPanel = {
  title: string;
  subtitle: string;
  subsubtitle: string;
  notes: string[];
  nodes: IntelNode[];
  edges: IntelEdge[];
};

interface Props {
  people: CollectionEntry<'people'>[];
}

const { people } = Astro.props as Props;

function buildIntelPanel(person: CollectionEntry<'people'>): IntelPanel {
  const centerX = 50;
  const centerY = 50;
  const radius = 33;
  const nodes = person.data.tags.map((tag: string, index: number) => {
    const angle = (-Math.PI / 2) + (Math.PI * 2 * index) / person.data.tags.length;
    const x = centerX + Math.cos(angle) * radius;
    const y = centerY + Math.sin(angle) * radius;
    return {
      id: `n-${index}`,
      label: tag,
      x,
      y,
      size: tag.length <= 2 ? 'sm' : 'md',
    } satisfies IntelNode;
  });
  const edges = nodes.map((node: IntelNode) => ({ fromX: centerX, fromY: centerY, toX: node.x, toY: node.y }));

  return {
    title: person.data.name,
    subtitle: person.data.subtitle,
    subsubtitle: person.data.subsubtitle,
    notes: person.data.notes,
    nodes,
    edges,
  };
}

const panels = people.map(buildIntelPanel);
---

<aside class="intel-board" id="intel-board">
  {panels.map((panel, panelIndex) => (
    <article class={`intel-board__panel${panelIndex === 0 ? ' is-active' : ''}`} data-intel-index={panelIndex}>
      <header class="intel-board__head">
        <p>{panel.subtitle}</p>
        <h2>{panel.title}</h2>
        <p>{panel.subsubtitle}</p>
      </header>

      <div class="intel-board__graph">
        <svg viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
          {panel.edges.map((edge) => (
            <line x1={edge.fromX} y1={edge.fromY} x2={edge.toX} y2={edge.toY}></line>
          ))}
        </svg>
        <div class="intel-board__avatar"></div>
        {panel.nodes.map((node) => (
          <span class={`intel-board__node is-${node.size}`} style={`left:${node.x}%;top:${node.y}%;`}>{node.label}</span>
        ))}
      </div>

      <ul class="intel-board__notes">
        {panel.notes.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
  ))}
</aside>

<script>
  const intelBoard = document.getElementById('intel-board');
  if (!intelBoard) throw new Error('intel-board not found');

  const intelPanels = Array.from(intelBoard.querySelectorAll('.intel-board__panel')) as HTMLElement[];

  function activatePanel(index: number) {
    intelPanels.forEach((panel, panelIndex) => {
      panel.classList.toggle('is-active', panelIndex === index);
    });
  }

  window.addEventListener('dossier-change', (event) => {
    const customEvent = event as CustomEvent<{ index: number }>;
    const nextIndex = customEvent.detail?.index ?? 0;
    activatePanel(nextIndex);
  });

  activatePanel(0);
</script>
